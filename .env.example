# Copy this to .env and fill in real values
# Never commit .env — excluded by .gitignore
# Frontend startup will fail fast if either required Supabase variable is missing.

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SENTRY_DSN="your-sentry-dsn-optional"

# Optional: set this for Edge Functions that need a canonical frontend redirect origin.
BURS_APP_URL="https://burs.me"

# Supabase Edge Functions
# Active AI functions use GEMINI_API_KEY (not LOVABLE_API_KEY).
GEMINI_API_KEY="your-google-ai-api-key"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Smoke tests (src/test/smoke/*) — P0d. Opt-in, off by default.
# Tests create test_<uuid>@smoketest.burs.invalid users, exercise auth/DB/storage,
# and tear themselves down. No Gemini or Stripe. Run: RUN_SMOKE=1 npm run test:smoke
RUN_SMOKE="0"
SUPABASE_SERVICE_ROLE_KEY_TEST="service-role-key-of-the-supabase-project-you-want-smoke-tests-to-run-against"
