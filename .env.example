# Copy this to .env and fill in real values
# Never commit .env — excluded by .gitignore
# Frontend startup will fail fast if either required Supabase variable is missing.

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SENTRY_DSN="your-sentry-dsn-optional"

# Optional: set this for Edge Functions that need a canonical frontend redirect origin.
BURS_APP_URL="https://burs.me"

# Supabase Edge Functions
# Active AI functions use GEMINI_API_KEY (not LOVABLE_API_KEY).
GEMINI_API_KEY="your-google-ai-api-key"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Smoke tests (src/test/smoke/*) — P0d. Opt-in, off by default.
# Tests create test_<uuid>@smoketest.burs.invalid users, exercise auth/DB/storage,
# and tear themselves down. No Gemini or Stripe. Run: RUN_SMOKE=1 npm run test:smoke
RUN_SMOKE="0"
SUPABASE_SERVICE_ROLE_KEY_TEST="service-role-key-of-the-supabase-project-you-want-smoke-tests-to-run-against"

# Stripe billing — Wave 8 P56.
# STRIPE_MODE=test|live picks which key set the edge functions use.
# Test keys/prices come from the Stripe Dashboard's Test mode toggle.
# Live keys/prices come from Live mode — required for production billing.
# create_checkout_session at line 21-30 reads these in pairs (test|live).
STRIPE_MODE="test"
STRIPE_SECRET_KEY_TEST="sk_test_..."
STRIPE_SECRET_KEY_LIVE="sk_live_..."
STRIPE_WEBHOOK_SECRET_TEST="whsec_..."
STRIPE_WEBHOOK_SECRET_LIVE="whsec_..."

# Stripe Price IDs — SEK pricing per Wave 8 P56 (Sweden launch market).
# Spec amounts: 119 SEK/month, 899 SEK/year. Create both Prices on the
# existing BURS Premium Product in the Stripe Dashboard (Products → BURS
# Premium → Add another price → Currency: SEK), then paste the resulting
# `price_xxx` IDs below. The same Price IDs charge every user regardless
# of locale — the localized display in src/lib/localizedPricing.ts is
# presentation only; the SEK ledger amount is single-currency.
STRIPE_PRICE_ID_MONTHLY_TEST="price_..._test_monthly_119_sek"
STRIPE_PRICE_ID_YEARLY_TEST="price_..._test_yearly_899_sek"
STRIPE_PRICE_ID_MONTHLY_LIVE="price_..._live_monthly_119_sek"
STRIPE_PRICE_ID_YEARLY_LIVE="price_..._live_yearly_899_sek"
