# Edge function environment reference (Deno).
#
# This file is documentation only — Supabase edge functions read secrets via
# `Deno.env.get(...)` from the project's runtime secrets, configured under
# Project Settings → Functions → Secrets. Copy this list when bootstrapping a
# preview project, never commit real values.
#
# Cron-body secrets (used by pg_cron triggers) live in `vault.secrets` —
# CLAUDE.md migration discipline notes that custom GUCs are world-readable.

# --- Supabase platform (auto-injected in deployed functions; required locally) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Frontend redirect origin (calendar, password reset, checkout return) ---
BURS_APP_URL=
ALLOWED_ORIGIN=
ALLOWED_CALENDAR_REDIRECT_URIS=

# --- Telemetry (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# --- AI (Gemini via OpenAI-compatible endpoint) ---
GEMINI_API_KEY=
GEMINI_URL_OVERRIDE=
GEMINI_TEXT_URL_OVERRIDE=
GEMINI_IMAGE_URL_OVERRIDE=

# --- Garment image pipeline (M28 / N6) ---
GARMENT_IMAGE_PROVIDER=
PHOTOROOM_API_KEY=
PHOTOROOM_API_BASE_URL=
RENDER_PIPELINE_ENABLED=
RENDER_WORKER_BEARER=

# --- Google OAuth (M36 calendar sync) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=

# --- Web push (legacy web-only path; Mobile uses Expo push) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Stripe (web-only billing surface; mobile uses RevenueCat / StoreKit) ---
STRIPE_MODE=
STRIPE_SECRET_KEY=
STRIPE_SECRET_KEY_TEST=
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_WEBHOOK_SECRET_LIVE=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_MONTHLY_TEST=
STRIPE_PRICE_ID_MONTHLY_LIVE=
STRIPE_PRICE_ID_YEARLY=
STRIPE_PRICE_ID_YEARLY_TEST=
STRIPE_PRICE_ID_YEARLY_LIVE=

# --- RevenueCat (M31 webhook) ---
# Header `Authorization: Bearer <REVENUECAT_WEBHOOK_SECRET>` validates webhooks;
# REVENUECAT_REST_API_KEY drives entitlement reconciliation calls.
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_REST_API_KEY=

# --- Test / staging escape hatches ---
ALLOW_SANDBOX_EVENTS=
