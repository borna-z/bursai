{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["burs"],
  "ios": {
    "iosModuleName": "BursGarmentDetector"
  },
  "android": {
    "androidNamespace": ["burs"],
    "androidCxxLibName": "BursGarmentDetector"
  },
  "autolinking": {
