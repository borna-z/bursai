{
  "expo": {
    "name": "BURS",
    "slug": "mobile",
    "scheme": ["burs", "me.burs.app"],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF7EF"
    },
    "ios": {
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png",
        "tinted": "./assets/icon-tinted.png"
      },
      "supportsTablet": true,
      "bundleIdentifier": "me.burs.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "BURS uses the camera to scan and add garments to your wardrobe.",
        "NSPhotoLibraryUsageDescription": "BURS reads photos from your library so you can add garments to your wardrobe.",
        "UIBackgroundModes": ["remote-notification"]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["85F4.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ],
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": []
      }
    },
    "android": {
      "package": "me.burs.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF7EF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "burs"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-localization",
      [
        "@sentry/react-native/expo",
        {
          "organization": "burs",
          "project": "burs-mobile"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0F172A",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "BURS uses the camera to scan and add garments to your wardrobe.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "BURS reads photos from your library so you can add garments to your wardrobe.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BURS uses your location to tailor outfits to local weather."
        }
      ],
      "./plugins/with-background-removal"
    ],
    "extra": {
      "eas": {
        "projectId": "00d9bb65-ab97-499d-9ee6-2db4a3725ed8"
      },
      "_iconNote": "Generated from src/assets/burs-logo.png via mobile/scripts/generate-app-icons.js. Cream #FBF7EF surface + black B-hanger mark for iOS light / Android / web; charcoal #0F172A + white mark for iOS dark; opaque white + black mark for iOS tinted (Expo flattens tinted onto #FFF and iOS applies user tint via multiply, so the glyph must be dark on light).",
      "_googleServicesNote": "TODO: replace google-services.json with the real Firebase config (downloaded from console.firebase.google.com → Project Settings → Android app) before Android production build. The committed file is a placeholder so dev builds and EAS bundling don't fail on the missing reference, but FCM push will not work against it."
    }
  }
}
