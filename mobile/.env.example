# Copy to mobile/.env and fill in real values.
# Expo inlines EXPO_PUBLIC_* at build time — same Supabase project as the web app (ref khvkwojtlkcvxjxztduj).
# Required keys are validated at runtime; optional keys gate feature surfaces (RevenueCat, Sentry).

# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://khvkwojtlkcvxjxztduj.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Sentry (optional in dev; required in EAS production builds)
EXPO_PUBLIC_SENTRY_DSN=

# RevenueCat (M31) — separate keys per platform
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
